<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" 
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.blog.mapper.CommentMapper">
    
    <resultMap id="BaseResultMap" type="com.blog.entity.Comment">
        <id column="id" property="id"/>
        <result column="article_id" property="articleId"/>
        <result column="user_id" property="userId"/>
        <result column="parent_id" property="parentId"/>
        <result column="content" property="content"/>
        <result column="status" property="status"/>
        <result column="create_time" property="createTime"/>
        <result column="user_name" property="userName"/>
        <result column="user_avatar" property="userAvatar"/>
    </resultMap>
    
    <sql id="Base_Column_List">
        c.id, c.article_id, c.user_id, c.parent_id, c.content, c.status, c.create_time
    </sql>
    
    <select id="findById" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM `comment` c
        WHERE c.id = #{id}
    </select>
    
    <select id="findByArticleId" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>,
               u.nickname as user_name,
               u.avatar as user_avatar
        FROM `comment` c
        LEFT JOIN `user` u ON c.user_id = u.id
        WHERE c.article_id = #{articleId}
        AND c.status = 1
        ORDER BY c.create_time DESC
    </select>
    
    <select id="findByUserId" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM `comment` c
        WHERE c.user_id = #{userId}
        ORDER BY c.create_time DESC
    </select>
    
    <select id="countByArticleId" resultType="int">
        SELECT COUNT(*)
        FROM `comment`
        WHERE article_id = #{articleId} AND status = 1
    </select>
    
    <insert id="insert" parameterType="com.blog.entity.Comment" 
            useGeneratedKeys="true" keyProperty="id">
        INSERT INTO `comment` (article_id, user_id, parent_id, content, status, create_time)
        VALUES (#{articleId}, #{userId}, #{parentId}, #{content}, 1, NOW())
    </insert>
    
    <update id="update" parameterType="com.blog.entity.Comment">
        UPDATE `comment`
        SET content = #{content}
        WHERE id = #{id}
    </update>
    
    <delete id="deleteById">
        DELETE FROM `comment` WHERE id = #{id}
    </delete>
    
    <delete id="deleteByArticleId">
        DELETE FROM `comment` WHERE article_id = #{articleId}
    </delete>
</mapper>
