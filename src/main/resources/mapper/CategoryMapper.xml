<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" 
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.blog.mapper.CategoryMapper">
    
    <resultMap id="BaseResultMap" type="com.blog.entity.Category">
        <id column="id" property="id"/>
        <result column="name" property="name"/>
        <result column="description" property="description"/>
        <result column="sort" property="sort"/>
        <result column="create_time" property="createTime"/>
    </resultMap>
    
    <sql id="Base_Column_List">
        id, name, description, sort, create_time
    </sql>
    
    <select id="findById" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM category
        WHERE id = #{id}
    </select>
    
    <select id="findAll" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM category
        ORDER BY sort ASC
    </select>
    
    <select id="findByStatus" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM category
        WHERE status = #{status}
        ORDER BY sort ASC
    </select>
    
    <insert id="insert" parameterType="com.blog.entity.Category" 
            useGeneratedKeys="true" keyProperty="id">
        INSERT INTO category (name, description, sort, create_time)
        VALUES (#{name}, #{description}, #{sort}, NOW())
    </insert>
    
    <update id="update" parameterType="com.blog.entity.Category">
        UPDATE category
        SET name = #{name},
            description = #{description},
            sort = #{sort}
        WHERE id = #{id}
    </update>
    
    <delete id="deleteById">
        DELETE FROM category WHERE id = #{id}
    </delete>
</mapper>
